# Copy to terraform.tfvars and fill in your values
aws_region  = "eu-south-2"
environment = "prod"

# Public IPv4 that AWS sees from your home VPN egress. Do not use the private
# LAN/VPN address here; use the public egress address with a /32 suffix.
allowed_ip_cidrs = ["YOUR_VPN_PUBLIC_IPV4/32"]

# Optional ALB HTTPS certificate. If set, OpenTofu creates and validates an ACM
# certificate with Route 53 DNS validation.
app_domain_name                           = null
app_route53_zone_id                       = null
app_route53_zone_name                     = null
app_certificate_subject_alternative_names = []

# Optional Cognito/ALB authentication with role groups. This requires
# app_domain_name plus an ACM certificate because ALB auth only works on HTTPS.
enable_cognito_auth  = false
cognito_domain_prefix = null
cognito_user_groups = {
  viewer = {
    description = "Can chat with the assistant about news only."
    precedence  = 30
  }
  investor = {
    description = "Can use market data, news, simulations, and reports, but not portfolio tools."
    precedence  = 20
  }
  admin = {
    description = "Can use every assistant service and administrative trading controls."
    precedence  = 10
  }
}

# RDS
db_name                            = "investments"
db_username                        = "investments"
db_password                        = "CHANGE_ME_STRONG_PASSWORD"
aurora_postgresql_engine_version   = null
# Optional extra secrets, also written to investments/prod:
app_secret_values = {
  # Basic Auth fallback for enable_cognito_auth=false.
  UI_AUTH_USERNAME = "investments"
  UI_AUTH_PASSWORD = "CHANGE_ME_STRONG_UI_PASSWORD"
  # REDIS_URL = "redis://:TOKEN@HOST:6379/0"
}

# Redis auth token (16-128 chars, excluding @, ", and /). Set to null to disable AUTH.
redis_auth_token = null
redis_node_type  = "cache.t3.micro"

# EKS node sizing
node_instance_type = "t3.medium"
node_min_size      = 2
node_max_size      = 5
node_desired_size  = 2
k8s_version        = "1.33"

# Dedicated node group for the self-hosted Ollama LLM pod.
enable_llm_node_group = true
llm_node_instance_type = "t3.xlarge"
llm_node_min_size      = 1
llm_node_max_size      = 2
llm_node_desired_size  = 1
