# Copy to terraform.tfvars and fill in your values
aws_region  = "eu-south-2"
environment = "prod"

# Your home IP (the only one that can reach the UI)
allowed_ip_cidrs = ["YOUR_HOME_IP/32"]

# Optional ALB HTTPS certificate. If set, Terraform creates and validates an ACM
# certificate with Route 53 DNS validation.
app_domain_name                           = null
app_route53_zone_id                       = null
app_route53_zone_name                     = null
app_certificate_subject_alternative_names = []

# RDS
db_name                            = "investments"
db_username                        = "investments"
db_password                        = "CHANGE_ME_STRONG_PASSWORD"
aurora_postgresql_engine_version   = null
# Optional extra secrets, also written to investments/prod:
app_secret_values = {
  # REDIS_URL = "redis://:TOKEN@HOST:6379/0"
}

# Redis auth token (16-128 chars, excluding @, ", and /). Set to null to disable AUTH.
redis_auth_token = null
redis_node_type  = "cache.t3.micro"

# EKS node sizing
node_instance_type = "t3.medium"
node_min_size      = 2
node_max_size      = 5
node_desired_size  = 2
k8s_version        = "1.33"

# Dedicated node group for the self-hosted Ollama LLM pod.
enable_llm_node_group = true
llm_node_instance_type = "t3.xlarge"
llm_node_min_size      = 1
llm_node_max_size      = 2
llm_node_desired_size  = 1
