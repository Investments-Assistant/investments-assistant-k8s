# ─────────────────────────────────────────────────────────────────────────────
# Investment Assistant K8s — Environment Variables
# Copy to .env and fill in all values before running.
# ─────────────────────────────────────────────────────────────────────────────

# ── Environment ───────────────────────────────────────────────────────────────
ENVIRONMENT=production
LOG_LEVEL=INFO
EXTERNAL_API_ACCESS=false

# ── Security — IP whitelist (comma-separated CIDRs) ───────────────────────────
# Your home IP + any VPN subnet you use to reach the ALB.
ALLOWED_IPS=YOUR_HOME_IP/32,YOUR_VPN_IP/32

# ── Self-hosted LLM ───────────────────────────────────────────────────────────
# Default target is the local Ollama-compatible service from docker-compose/k8s.
LLM_BASE_URL=http://llm:11434/v1
LLM_API_KEY=
LLM_MODEL_NAME=llama3.1:8b
AGENT_MAX_TOKENS=4096
AGENT_TEMPERATURE=0.1
AGENT_MAX_CONTEXT_MESSAGES=50
AGENT_MAX_TOOL_ITERATIONS=8
LLM_REQUEST_TIMEOUT_SECONDS=3600

# ── Trading Safety Limits ─────────────────────────────────────────────────────
TRADING_MODE=recommend         # recommend | auto
AUTO_MAX_TRADE_USD=500.0
AUTO_DAILY_LOSS_LIMIT_USD=1000.0
AUTO_ALLOWED_SYMBOLS=          # empty = all; or: AAPL,BTC-USD,ETH-USD

# ── PostgreSQL (RDS Aurora) ───────────────────────────────────────────────────
POSTGRES_HOST=your-aurora-cluster.cluster-xxxx.eu-south-2.rds.amazonaws.com
POSTGRES_PORT=5432
POSTGRES_DB=investment_assistant
POSTGRES_USER=ia_user
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_SSL_MODE=disable

# ── Redis (ElastiCache) ───────────────────────────────────────────────────────
REDIS_URL=redis://your-elasticache.xxxx.cache.amazonaws.com:6379/0

# ── Internal service URLs (K8s DNS) — override for local docker-compose ──────
MARKET_DATA_URL=http://market-data:8001
NEWS_URL=http://news:8002
PORTFOLIO_URL=http://portfolio:8003
SIMULATION_URL=http://simulation:8004
SCHEDULER_URL=http://scheduler:8005
FOREX_URL=http://forex:8006
GATEWAY_URL=http://gateway:8000

# ── Optional external integrations (disabled while EXTERNAL_API_ACCESS=false) ─
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_PAPER=true

IBKR_HOST=127.0.0.1
IBKR_PORT=4002
IBKR_CLIENT_ID=1
IBKR_ENABLED=false

COINBASE_API_KEY=
COINBASE_API_SECRET=

BINANCE_API_KEY=
BINANCE_SECRET_KEY=
BINANCE_TESTNET=true

NEWSAPI_KEY=
GUARDIAN_API_KEY=

NEWSLETTER_IMAP_SERVER=imap.gmail.com
NEWSLETTER_IMAP_PORT=993
NEWSLETTER_EMAIL_USER=
NEWSLETTER_EMAIL_PASSWORD=
NEWSLETTER_SENDER_FILTER=

# ── Scheduler ─────────────────────────────────────────────────────────────────
MARKET_DATA_REFRESH_MINUTES=5
WEEKLY_REPORT_DAY=6          # 0=Mon … 6=Sun
WEEKLY_REPORT_HOUR=18
WEEKLY_REPORT_MINUTE=0

# ── Reports ───────────────────────────────────────────────────────────────────
REPORTS_DIR=/app/reports
